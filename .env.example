# Copie este arquivo para .env e preencha com os seus valores reais.
# NUNCA envie o arquivo .env para o Git ou compartilhe publicamente.

# Bot principal Sniper / Analista
TELEGRAM_TOKEN_ANALISTA=seu_token_telegram_aqui
GEMINI_API_KEY_ANALISTA=sua_chave_gemini_aqui

# Bot de suporte EDS
TELEGRAM_TOKEN_SUPORTE=seu_token_telegram_aqui
GEMINI_API_KEY_SUPORTE=sua_chave_gemini_aqui
SUPPORT_EMAIL=supportedsi@gmail.com

# Define qual bot o entrypoint main.py deve iniciar no deploy.
# Opcoes: suporte, analista, ambos
BOT_TARGET=suporte
