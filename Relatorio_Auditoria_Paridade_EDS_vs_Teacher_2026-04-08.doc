  <tr><th>Arquivo</th><th>Principal</th><th>BACKUP</th><th>Delta</th></tr>
  <tr><td><code>index.html</code></td><td>2.857 linhas (158 KB)</td><td>2.380 linhas (129 KB)</td><td class="red">+477 linhas (+29 KB)</td></tr>
  <tr><td><code>data/brasileirao2026.js</code></td><td>2.558 linhas (63 KB)</td><td>2.298 linhas (50 KB)</td><td class="red">+260 linhas (+13 KB)</td></tr>
  <tr><td><code>data/mls2026.js</code></td><td>3.152 linhas (77 KB)</td><td>2.627 linhas (46 KB)</td><td class="red">+525 linhas (+31 KB)</td></tr>
  <tr><td><code>data/argentina2026.js</code></td><td>Presente</td><td>Presente</td><td>Nao comparado</td></tr>
